// CareLine Telegram Mini App — Prisma Schema
// Enterprise-grade database schema for napkin manufacturing business operations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum OperationType {
  SALE
  CLIENT_PAYMENT
  CASH_EXPENSE
}

enum PaymentMethod {
  CASH
  CARD_TRANSFER
  BANK_TRANSFER
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

// ─── Telegram User (authenticated via initData) ─────────────────────────────

model TelegramUser {
  id          String   @id @default(cuid())
  telegramId  BigInt   @unique
  firstName   String
  lastName    String?
  username    String?
  photoUrl    String?
  role        UserRole @default(OPERATOR)
  isActive    Boolean  @default(true)
  lastLoginAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  operations Operation[]
  auditLogs  AuditLog[]

  @@index([telegramId])
  @@map("telegram_users")
}

// ─── Client (покупатели салфеток) ───────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  comment   String?
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  operations Operation[]

  @@index([name])
  @@index([phone])
  @@index([isActive])
  @@map("clients")
}

// ─── Employee (сотрудники) ──────────────────────────────────────────────────

model Employee {
  id        String   @id @default(cuid())
  fullName  String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  operations Operation[]

  @@index([fullName])
  @@index([isActive])
  @@map("employees")
}

// ─── Product (товары — салфетки) ────────────────────────────────────────────

model Product {
  id           String   @id @default(cuid())
  name         String
  dimensions   String?
  defaultPrice Decimal  @default(0) @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  operationItems OperationItem[]

  @@index([isActive, sortOrder])
  @@map("products")
}

// ─── Expense Type (типы расходов) ───────────────────────────────────────────

model ExpenseType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  operations Operation[]

  @@index([isActive])
  @@map("expense_types")
}

// ─── Payment Card (карты для переводов) ─────────────────────────────────────

model PaymentCard {
  id         String   @id @default(cuid())
  cardNumber String
  holderName String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  operations Operation[]

  @@index([isActive])
  @@map("payment_cards")
}

// ─── Cash Holder (у кого деньги) ────────────────────────────────────────────

model CashHolder {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  operations Operation[]

  @@index([isActive])
  @@map("cash_holders")
}

// ─── Operation (главная сущность — операции) ────────────────────────────────

model Operation {
  id            String        @id @default(cuid())
  type          OperationType
  totalAmount   Decimal       @db.Decimal(12, 2)
  
  // Sale / Payment fields
  clientId      String?
  client        Client?       @relation(fields: [clientId], references: [id])
  
  // Expense fields
  employeeId    String?
  employee      Employee?     @relation(fields: [employeeId], references: [id])
  expenseTypeId String?
  expenseType   ExpenseType?  @relation(fields: [expenseTypeId], references: [id])
  
  // Payment method fields
  paymentMethod PaymentMethod?
  paymentCardId String?
  paymentCard   PaymentCard?  @relation(fields: [paymentCardId], references: [id])
  cashHolderId  String?
  cashHolder    CashHolder?   @relation(fields: [cashHolderId], references: [id])
  cardRecipient String?       // "На чью карту"
  
  // Meta
  comment       String?
  receiptUrl    String?       // URL to uploaded receipt photo
  
  // Audit
  createdById   String
  createdBy     TelegramUser  @relation(fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  items         OperationItem[]

  @@index([type])
  @@index([clientId])
  @@index([employeeId])
  @@index([createdAt])
  @@index([createdById])
  @@index([type, createdAt])
  @@map("operations")
}

// ─── Operation Item (позиции в продаже) ─────────────────────────────────────

model OperationItem {
  id          String    @id @default(cuid())
  operationId String
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int
  price       Decimal   @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())

  @@index([operationId])
  @@index([productId])
  @@map("operation_items")
}

// ─── Audit Log (журнал действий) ────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // CREATE, UPDATE, DELETE
  entity    String   // Operation, Client, Employee, etc.
  entityId  String
  oldData   Json?
  newData   Json?
  userId    String
  user      TelegramUser @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
